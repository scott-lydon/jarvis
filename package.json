{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time voice assistant for frontline workers. OpenAI Realtime GA + grounded tool calling + cross-session memory.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run tests/property",
    "test:load": "vitest run tests/load --testTimeout=120000",
    "smoke:wttr": "JARVIS_REQUIRE_LIVE_WTTR=1 vitest run tests/smoke/wttr.test.ts",
    "smoke:openai": "vitest run tests/smoke/openai-realtime.test.ts --testTimeout=30000",
    "smoke:deployed": "vitest run tests/smoke/deployed.test.ts",
    "smoke:slice11": "JARVIS_REQUIRE_LIVE_GITHUB=1 vitest run tests/smoke/github-agentic.test.ts --testTimeout=30000",
    "db:migrate": "tsx src/db/migrate.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.7",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
