# Required at Slice 1 (voice round-trip).
# Get at: https://platform.openai.com/api-keys
# Format: sk-... or sk-proj-...
OPENAI_API_KEY=

# Optional at Slice 5+ (GitHub read tool).
# LOCAL DEV shortcut: GITHUB_TOKEN=$(gh auth token) npm run dev
# RENDER deploy: paste a fine-grained PAT here with permissions:
#   Contents: Read and write
#   Issues: Read
#   Pull requests: Read and write
#   Metadata: Read (auto)
GITHUB_TOKEN=

# Optional config (defaults shown).
WTTR_BASE_URL=https://wttr.in
JARVIS_DB_PATH=./data/jarvis.db
PORT=3000
